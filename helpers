function docker_build_omni() {
    local target="${1:-dev}"
    local tag="omnidrones:isaac"
    local build_cmd=(docker build)
    local isaacsim_context="$ISAACSIM_PATH"
    local build_args=()

    if [[ "$target" == "eecs" ]]; then
      tag="omnidrones:eecs"
      build_cmd=(docker buildx build)
      build_args+=(--load)
      if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
        build_args+=(--ssh default)
      else
        echo "ERROR: SSH_AUTH_SOCK not set; private repo clone will fail." >&2
        return 1
      fi
      # Stage Isaac Sim to avoid permission errors in cache dirs
      isaacsim_context="$(mktemp -d)"
      echo "Staging Isaac Sim into ${isaacsim_context}..."
      rsync -a --delete --info=progress2 \
        --exclude 'kit/cache/**' \
        --exclude 'kit/logs/**' \
        --exclude 'kit/data/Kit/Isaac-Sim Python/**' \
        --exclude '*.dmp' \
        --exclude '.nv/**' \
        "$ISAACSIM_PATH"/ "$isaacsim_context"/
    fi

    DOCKER_BUILDKIT=1 "${build_cmd[@]}" --network=host \
        --build-arg HOST_UID="$(id -u)" \
        --build-arg HOST_GID="$(id -g)" \
        --build-context isaacsim="$isaacsim_context" \
        --target "$target" \
        -f "$OMNI_DRONES_DIR"/docker/Dockerfile \
        -t "$tag" \
        --progress=plain \
        "${build_args[@]}" \
        "$OMNI_DRONES_DIR"

    if [[ "$target" == "eecs" ]]; then
      rm -rf "$isaacsim_context"
    fi
}

function docker_run_omni() {
  local venv_dir="${1:-omnidrones_venv_latest}"
  local isaacsim_cache_dir
  local cache_dir

  if [[ -z "${OMNI_DRONES_DIR:-}" ]]; then
    echo "ERROR: OMNI_DRONES_DIR is not set." >&2
    return 1
  fi

  isaacsim_cache_dir="${OMNI_DRONES_DIR}/cache_sim"
  cache_dir="${OMNI_DRONES_DIR}/.cache"

  # GPU selection priority:
  # 1) Slurm-assigned GPU(s)
  # 2) Existing CUDA_VISIBLE_DEVICES
  # 3) Local non-Slurm fallback: GPU 0
  local assigned_gpus=""
  local gpu_source=""

  if [[ -n "${SLURM_STEP_GPUS:-}" ]]; then
    assigned_gpus="${SLURM_STEP_GPUS}"
    gpu_source="SLURM_STEP_GPUS"
  elif [[ -n "${SLURM_JOB_GPUS:-}" ]]; then
    assigned_gpus="${SLURM_JOB_GPUS}"
    gpu_source="SLURM_JOB_GPUS"
  elif [[ -n "${CUDA_VISIBLE_DEVICES:-}" ]]; then
    assigned_gpus="${CUDA_VISIBLE_DEVICES}"
    gpu_source="CUDA_VISIBLE_DEVICES"
  else
    assigned_gpus="0"
    gpu_source="default local fallback"
  fi

  echo "Using GPU(s): $assigned_gpus (source: $gpu_source)"
  if [[ -z "$assigned_gpus" ]]; then
    echo "ERROR: Could not determine assigned GPU(s)." >&2
    echo "Expected one of SLURM_STEP_GPUS, SLURM_JOB_GPUS, or CUDA_VISIBLE_DEVICES to be set." >&2
    return 1
  fi

  # If only the assigned GPU(s) are exposed to the container, Isaac Sim should
  # use renderer GPU 0 (or 0..N-1 if multiple are exposed). For your case,
  # Slurm gave you one GPU, so activeGpu=0 is correct inside Docker.
  local isaacsim_renderer_args="--/renderer/multiGpu/enabled=false --/renderer/activeGpu=0"

  if [[ "$venv_dir" == */* ]]; then
    mkdir -p "$venv_dir"
    echo "Using host venv path: $venv_dir"
  else
    echo "Using Docker named volume: $venv_dir"
    if docker volume inspect "$venv_dir" >/dev/null 2>&1; then
      echo "Docker volume exists; re-using: $venv_dir"
    else
      echo "Docker volume not found; it will be created: $venv_dir"
    fi
  fi

  mkdir -p "$OMNI_DRONES_DIR/docker/.home"
  mkdir -p "$OMNI_DRONES_DIR/.outputs"
  mkdir -p "$OMNI_DRONES_DIR/.tmp_wandb"
  mkdir -p "$isaacsim_cache_dir"
  mkdir -p "$cache_dir"

  cd "$HOME" || return 1

  # Allow local docker containers to connect to X (skip if headless/SSH)
  if [[ -n "${DISPLAY:-}" ]]; then
    xhost +local:docker >/dev/null 2>&1 || true
  fi

  # Writable runtime dir for X/Wayland/Vulkan tooling that expects it
  local runtime_dir="/tmp/runtime-$(id -u)"
  mkdir -p "$runtime_dir"
  chmod 700 "$runtime_dir"

  # Xauthority passthrough (optional)
  local xauthority_path="$HOME/.Xauthority"
  local -a xauth_args=()
  if [[ -f "$xauthority_path" ]]; then
    xauth_args=(
      -e "XAUTHORITY=$xauthority_path"
      -v "$xauthority_path:$xauthority_path:ro"
    )
  fi

  # Find NVIDIA Vulkan ICD json on the host
  local -a nvidia_icd_hosts=(/usr/share/vulkan/icd.d/*nvidia*.json /etc/vulkan/icd.d/*nvidia*.json)
  local -a vk_icd_filenames_list=()
  local -a vk_icd_mount_args=()
  local -a extra_vk_args=()
  local vk_icd_container_root="/tmp/host_vulkan"

  local icd
  for icd in "${nvidia_icd_hosts[@]}"; do
    if [[ -f "$icd" ]]; then
      local icd_basename
      icd_basename="$(basename "$icd")"
      local icd_container_path="${vk_icd_container_root}/${icd_basename}"
      vk_icd_filenames_list+=("$icd_container_path")
      vk_icd_mount_args+=(-v "$icd:$icd_container_path:ro")
    fi
  done

  if [[ ${#vk_icd_filenames_list[@]} -gt 0 ]]; then
    extra_vk_args+=(
      "${vk_icd_mount_args[@]}"
      -e "VK_ICD_FILENAMES=$(IFS=:; echo "${vk_icd_filenames_list[*]}")"
    )
  else
    echo "WARNING: No NVIDIA Vulkan ICD JSON found on host." >&2
  fi

  # Optional: expose host NVIDIA user-space libs if your image depends on them
  local -a host_lib_args=(
    -v /lib/x86_64-linux-gnu:/host_lib:ro
    -v /usr/lib/x86_64-linux-gnu:/host_usr_lib:ro
    -e LD_LIBRARY_PATH=/host_lib:/host_usr_lib
  )

  echo "Using assigned GPU(s): $assigned_gpus"
  echo "Inside container, Isaac Sim renderer should use: $isaacsim_renderer_args"

  docker run --rm -it \
    --runtime=nvidia \
    --gpus "device=${assigned_gpus}" \
    --network=host \
    "${xauth_args[@]}" \
    -v "$OMNI_DRONES_DIR:/workspace/omni_drones:rw" \
    -v "$venv_dir:/opt/venv:rw" \
    -v "$OMNI_DRONES_DIR/docker/.home:/home/$(id -un)" \
    -v "$OMNI_DRONES_DIR/.hydra_outputs:/workspace/omni_drones/.hydra_outputs:rw" \
    -v "$OMNI_DRONES_DIR/.tmp_wandb:/tmp/wandb:rw" \
    -v "$isaacsim_cache_dir:/workspace/isaacsim/kit/cache:rw" \
    -v /tmp/.X11-unix:/tmp/.X11-unix:rw \
    -v "$runtime_dir:$runtime_dir:rw" \
    -v "$cache_dir:/workspace/omni_drones/.cache:rw" \
    -e HOME=/workspace/omni_drones \
    -e HOST_UID="$(id -u)" \
    -e HOST_GID="$(id -g)" \
    -e XDG_CACHE_HOME=/workspace/omni_drones/.cache \
    -e XDG_CONFIG_HOME=/workspace/omni_drones/.config \
    -e XDG_DATA_HOME=/workspace/omni_drones/.local/share \
    -e XDG_RUNTIME_DIR="$runtime_dir" \
    -e DISPLAY="${DISPLAY:-}" \
    -e NVIDIA_DRIVER_CAPABILITIES=compute,utility,graphics,display \
    -e NVIDIA_VISIBLE_DEVICES="$assigned_gpus" \
    -e ISAACSIM_RENDERER_ARGS="$isaacsim_renderer_args" \
    -e __GLX_VENDOR_LIBRARY_NAME=nvidia \
    -e VK_LOADER_LAYERS_DISABLE=VK_LAYER_MESA_device_select \
    -e WANDB_API_KEY=$WANDB_API_KEY \
    "${host_lib_args[@]}" \
    "${extra_vk_args[@]}" \
    omnidrones:eecs \
    bash -i
}

function docker_push_omni(){
    docker tag omnidrones:eecs mjsucb/omnidrones:eecs
    docker push mjsucb/omnidrones:eecs
    echo "Pushed omnidrones:eecs to Docker Hub"
    echo "Make sure to delete mjsucb/omnidrones:eecs tag if needed"
}
function docker_pull_omni(){
  docker pull mjsucb/omnidrones:eecs
  docker tag mjsucb/omnidrones:eecs omnidrones:eecs
}

function docker_delete_omni_volume() {
  echo "Deleting omnidrones_venv_latest volume"
  read -p "Press Enter to continue"
  docker volume rm omnidrones_venv_latest
}

function docker_omni_inspect() {
  local container_id
  container_id=$(docker ps --filter "ancestor=omnidrones:eecs" --format "{{.ID}}" | head -n1)
  if [[ -z "$container_id" ]]; then
    echo "No running container found for omnidrones:eecs" >&2
    return 1
  fi
  echo "Container: $container_id"
  docker inspect "$container_id" --format '{{range .Mounts}}{{.Source}} -> {{.Destination}}{{"\n"}}{{end}}'
}

function distrobox_create() {
  if [[ -n "${CONDA_DEFAULT_ENV:-}" || -n "${CONDA_PREFIX:-}" ]]; then
    echo "ERROR: Please deactivate your conda environment before running distrobox_create." >&2
    return 1
  fi
  
  echo "Creating distrobox container"
  local host_omni_dir="${OMNI_DRONES_DIR}"
  local venv_dir="${host_omni_dir}/.venv"
  local isaacsim_cache_dir="${host_omni_dir}/cache_sim"
  mkdir -p "$venv_dir"
  mkdir -p "$isaacsim_cache_dir"
  mkdir -p "/tmp/runtime-$(id -u)"

  distrobox create --verbose --hostname omnidrones -n omnidrones -i docker.io/mjsucb/omnidrones:eecs \
    --additional-flags "--userns=keep-id" \
    --volume /var/lib/sss/pipes:/var/lib/sss/pipes \
    --volume $OMNI_DRONES_DIR:/workspace/omni_drones:rw \
    --volume "$venv_dir":/opt/venv:rw \
    --nvidia \
    -a "--device /dev/dri" \
    -a "--volume /tmp/.X11-unix:/tmp/.X11-unix:rw" \
    -a "--env HOME=/workspace/omni_drones" \
    -a "--env XDG_CACHE_HOME=/workspace/omni_drones/.cache" \
    -a "--env XDG_CONFIG_HOME=/workspace/omni_drones/.config" \
    -a "--env XDG_DATA_HOME=/workspace/omni_drones/.local/share" \
    -a "--env XDG_RUNTIME_DIR=/tmp/runtime-$(id -u)" \
    -a "--env DISPLAY=${DISPLAY}" \
    -a "--env NVIDIA_DRIVER_CAPABILITIES=compute,utility,graphics,display" \
    -a "--env __GLX_VENDOR_LIBRARY_NAME=nvidia" \
    -a "--env VK_LOADER_LAYERS_DISABLE=VK_LAYER_MESA_device_select" \
    -a "--volume /lib/x86_64-linux-gnu:/host_lib:ro" \
    -a "--volume /usr/lib/x86_64-linux-gnu:/host_usr_lib:ro" \
    -a "--volume $isaacsim_cache_dir:/workspace/isaacsim/kit/cache:rw" \
    -a "--env LD_LIBRARY_PATH=/host_lib:/host_usr_lib"
}

function podman_omnidrones_create() {
  if [[ -n "${CONDA_DEFAULT_ENV:-}" || -n "${CONDA_PREFIX:-}" ]]; then
    echo "ERROR: Please deactivate your conda environment before running podman_omnidrones_create." >&2
    return 1
  fi

  if [[ -z "${OMNI_DRONES_DIR:-}" ]]; then
    echo "ERROR: OMNI_DRONES_DIR is not set." >&2
    return 1
  fi

  local host_omni_dir="${OMNI_DRONES_DIR}"
  local venv_dir="${host_omni_dir}/.venv"
  local isaacsim_cache_dir="${host_omni_dir}/cache_sim"
  local cache_dir="${host_omni_dir}/.cache"
  local runtime_dir="/tmp/runtime-$(id -u)"
  local local_vk_dir="${runtime_dir}/podman_vk"
  local local_vk_json="${local_vk_dir}/nvidia_icd.json"

  mkdir -p "$venv_dir" "$isaacsim_cache_dir" "$cache_dir" "$runtime_dir" "$local_vk_dir"
  chmod 700 "$runtime_dir"

  local gpu_id="${SLURM_STEP_GPUS:-${SLURM_JOB_GPUS:-${CUDA_VISIBLE_DEVICES:-0}}}"
  gpu_id="${gpu_id%%,*}"

  local -a nvidia_device_args=()
  local -a base_nvidia_device_args=()

  if [[ "$gpu_id" =~ ^[0-9]+$ ]] && [[ -e "/dev/nvidia${gpu_id}" ]]; then
    nvidia_device_args+=(--device "/dev/nvidia${gpu_id}:/dev/nvidia${gpu_id}")
  else
    echo "WARNING: Could not find /dev/nvidia${gpu_id}; exposing all /dev/nvidia[0-9]* nodes." >&2
    local dev
    for dev in /dev/nvidia[0-9]*; do
      [[ -e "$dev" ]] || continue
      nvidia_device_args+=(--device "${dev}:${dev}")
    done
  fi

  local dev
  for dev in /dev/nvidiactl /dev/nvidia-uvm /dev/nvidia-uvm-tools /dev/nvidia-modeset /dev/nvidia-caps/*; do
    [[ -e "$dev" ]] || continue
    base_nvidia_device_args+=(--device "${dev}:${dev}")
  done

  local isaacsim_renderer_args="--/renderer/multiGpu/enabled=false --/renderer/activeGpu=0"

  local xauthority_path="$HOME/.Xauthority"
  local -a xauth_args=()
  if [[ -f "$xauthority_path" ]]; then
    xauth_args=(
      -e "XAUTHORITY=$xauthority_path"
      -v "$xauthority_path:$xauthority_path:ro"
    )
  fi

  cat > "$local_vk_json" <<EOF
{
  "file_format_version": "1.0.1",
  "ICD": {
    "library_path": "/host_lib/libGLX_nvidia.so.0",
    "api_version": "1.4.303"
  }
}
EOF

  echo "Recreating podman container omnidrones on GPU selector ${gpu_id}"
  podman rm -f omnidrones >/dev/null 2>&1 || true

  podman run -d \
    --name omnidrones \
    --hostname omnidrones \
    --userns=keep-id \
    --security-opt label=disable \
    --network=host \
    "${nvidia_device_args[@]}" \
    "${base_nvidia_device_args[@]}" \
    --device /dev/dri \
    -v /usr/bin/nvidia-smi:/usr/bin/nvidia-smi:ro \
    -v /lib/x86_64-linux-gnu:/host_lib:ro \
    -v "$local_vk_json:/tmp/host_vulkan/nvidia_icd.json:ro" \
    "${xauth_args[@]}" \
    -v /var/lib/sss/pipes:/var/lib/sss/pipes \
    -v "${host_omni_dir}:/workspace/omni_drones:rw" \
    -v "${venv_dir}:/opt/venv:rw" \
    -v "${isaacsim_cache_dir}:/workspace/isaacsim/kit/cache:rw" \
    -v "${cache_dir}:/workspace/omni_drones/.cache:rw" \
    -v /tmp/.X11-unix:/tmp/.X11-unix:rw \
    -v "${runtime_dir}:${runtime_dir}:rw" \
    -e HOME=/workspace/omni_drones \
    -e XDG_CACHE_HOME=/workspace/omni_drones/.cache \
    -e XDG_CONFIG_HOME=/workspace/omni_drones/.config \
    -e XDG_DATA_HOME=/workspace/omni_drones/.local/share \
    -e XDG_RUNTIME_DIR="${runtime_dir}" \
    -e DISPLAY="${DISPLAY:-}" \
    -e NVIDIA_DRIVER_CAPABILITIES=compute,utility,graphics,display \
    -e NVIDIA_VISIBLE_DEVICES="${gpu_id}" \
    -e ISAACSIM_RENDERER_ARGS="${isaacsim_renderer_args}" \
    -e __GLX_VENDOR_LIBRARY_NAME=nvidia \
    -e VK_LOADER_LAYERS_DISABLE=VK_LAYER_MESA_device_select \
    -e VK_ICD_FILENAMES=/tmp/host_vulkan/nvidia_icd.json \
    -e LD_LIBRARY_PATH=/host_lib \
    docker.io/mjsucb/omnidrones:eecs \
    bash -lc 'while true; do sleep 3600; done'
}
function podman_omnidrones_enter() {
  podman exec -it omnidrones env -u CUDA_VISIBLE_DEVICES -u NVIDIA_VISIBLE_DEVICES bash -i
}


function podman_omnidrones_end() {
  podman rm -f omnidrones
}

function distrobox_enter() {
  distrobox enter omnidrones -- bash -i
}


function distrobox_end() {
  distrobox stop omnidrones 2>/dev/null || true
  distrobox rm -f omnidrones
  podman rm -f omnidrones 2>/dev/null || true
}